---
// src/components/CookieBanner.astro
---

<div id="cookie-banner" class="cookie-banner" style="display: none;">
  <!-- Vista Principal -->
  <div id="cookie-main-view" class="cookie-content">
    <p>
      Utilizamos cookies técnicas, analíticas y de marketing para brindar una mejor experiencia, asegurar la plataforma y mejorar el contenido. Puedes ajustar tus preferencias o aceptarlas todas. <a href="/cookies">Más información</a>.
    </p>
    <div class="cookie-buttons">
      <button id="cookie-btn-config" class="btn btn-secondary">Modificar preferencias</button>
      <button id="cookie-btn-accept-all" class="btn btn-primary">Aceptar todas</button>
    </div>
  </div>

  <!-- Vista de Configuración (Inicialmente oculta) -->
  <div id="cookie-settings-view" class="cookie-content" style="display: none;">
    <h3 class="settings-title">Configuración de Privacidad</h3>
    <div class="cookie-toggle-list">
      
      <!-- Necesarias -->
      <div class="cookie-toggle-item">
        <div class="toggle-info">
          <strong>Estrictamente Necesarias</strong>
          <p>Indispensables para que navegues con normalidad, resuelvas los retos de seguridad y mantengas preferencias como el tema oscuro visual.</p>
        </div>
        <label class="toggle-switch disabled">
          <input type="checkbox" checked disabled />
          <span class="slider"></span>
        </label>
      </div>
      
      <!-- Analíticas -->
      <div class="cookie-toggle-item">
        <div class="toggle-info">
          <strong>Cookies Analíticas</strong>
          <p>Nos ayudan a contar visitas y fuentes de tráfico midiendo qué interactúas más en la web, usando Google Analytics de forma pasiva.</p>
        </div>
        <label class="toggle-switch">
          <input type="checkbox" id="toggle-analytics" checked />
          <span class="slider"></span>
        </label>
      </div>

      <!-- Marketing -->
      <div class="cookie-toggle-item">
        <div class="toggle-info">
          <strong>Cookies de Publicidad</strong>
          <p>Trazabilidad empleada por redes publicitarias asociadas para ofrecerte oportunidades y publicidad relevante a futuro.</p>
        </div>
        <label class="toggle-switch">
          <input type="checkbox" id="toggle-marketing" checked />
          <span class="slider"></span>
        </label>
      </div>
    </div>
    
    <div class="cookie-buttons" style="margin-top: 20px;">
      <button id="cookie-btn-save" class="btn btn-primary" style="width: 100%;">Guardar preferencias</button>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    const banner = document.getElementById('cookie-banner');
    const mainView = document.getElementById('cookie-main-view');
    const settingsView = document.getElementById('cookie-settings-view');
    
    const btnAcceptAll = document.getElementById('cookie-btn-accept-all');
    const btnConfig = document.getElementById('cookie-btn-config');
    const btnSave = document.getElementById('cookie-btn-save');
    
    const toggleAnalytics = document.getElementById('toggle-analytics');
    const toggleMarketing = document.getElementById('toggle-marketing');

    // Parse current consent JSON
    let currentConsent = null;
    try {
      const stored = localStorage.getItem('cookie_consent_granular');
      if (stored) {
        currentConsent = JSON.parse(stored);
      }
    } catch(e) {
      console.error('Error parseando cookies locales');
    }

    const applyConsentToGtag = (prefs) => {
      if (typeof gtag === 'function') {
        gtag('consent', 'update', {
          'analytics_storage': prefs.analytics ? 'granted' : 'denied',
          'ad_storage': prefs.marketing ? 'granted' : 'denied',
          'ad_user_data': prefs.marketing ? 'granted' : 'denied',
          'ad_personalization': prefs.marketing ? 'granted' : 'denied'
        });
      }
    };

    if (!currentConsent) {
      banner.style.display = 'block';
    } else {
      applyConsentToGtag(currentConsent);
    }

    const hideBanner = () => {
      banner.style.opacity = '0';
      setTimeout(() => { banner.style.display = 'none'; }, 300);
    };

    btnAcceptAll.addEventListener('click', () => {
      const prefs = { analytics: true, marketing: true };
      localStorage.setItem('cookie_consent_granular', JSON.stringify(prefs));
      applyConsentToGtag(prefs);
      hideBanner();
    });

    btnConfig.addEventListener('click', () => {
      mainView.style.display = 'none';
      settingsView.style.display = 'block';
    });

    // Al guardar preferencias del panel, registramos el state de los checkboxes
    btnSave.addEventListener('click', () => {
      const prefs = {
        analytics: toggleAnalytics.checked,
        marketing: toggleMarketing.checked
      };
      localStorage.setItem('cookie_consent_granular', JSON.stringify(prefs));
      applyConsentToGtag(prefs);
      hideBanner();
    });
  })();
</script>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 24px;
    left: 24px;
    right: 24px;
    max-width: 600px;
    z-index: 9999;
    background: rgba(var(--bg-primary-rgb), 0.98); 
    background-color: var(--bg-primary);
    border: 1px solid var(--border-color);
    box-shadow: 0 10px 40px rgba(0,0,0,0.15);
    border-radius: 16px;
    padding: 1.5rem;
    transition: opacity 0.3s ease;
  }
  :global(.dark) .cookie-banner {
    box-shadow: 0 10px 40px rgba(0,0,0,0.8);
  }

  .cookie-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cookie-content p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  .cookie-content p a {
    color: var(--accent);
    text-decoration: underline;
  }

  .settings-title {
    margin: 0;
    font-size: 1.15rem;
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 10px;
    margin-bottom: 10px;
  }

  .cookie-toggle-list {
    display: flex;
    flex-direction: column;
    gap: 15px;
    max-height: 400px;
    overflow-y: auto;
    padding-right: 10px;
  }

  .cookie-toggle-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    padding: 10px;
    background: var(--bg-secondary);
    border-radius: 10px;
    border: 1px solid var(--border-color);
  }

  .toggle-info strong {
    display: block;
    margin-bottom: 4px;
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  .toggle-info p {
    font-size: 0.8rem;
    line-height: 1.35;
    margin: 0;
  }

  /* Toogle Switch UI */
  .toggle-switch {
    position: relative;
    display: inline-block;
    width: 46px;
    height: 24px;
    flex-shrink: 0;
  }

  .toggle-switch input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .slider {
    position: absolute;
    cursor: pointer;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: var(--border-color);
    transition: .3s;
    border-radius: 24px;
  }

  .slider:before {
    position: absolute;
    content: "";
    height: 18px;
    width: 18px;
    left: 3px;
    bottom: 3px;
    background-color: white;
    transition: .3s;
    border-radius: 50%;
  }

  input:checked + .slider {
    background-color: var(--accent);
  }

  input:checked + .slider:before {
    transform: translateX(22px);
  }

  .toggle-switch.disabled .slider {
    background-color: #a0aec0;
    cursor: not-allowed;
    opacity: 0.5;
  }

  /* Botones */
  .cookie-buttons {
    display: flex;
    gap: 0.75rem;
    justify-content: flex-end;
  }

  .cookie-buttons .btn {
    padding: 0.6rem 1.25rem;
    font-size: 0.95rem;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
  }

  .cookie-buttons .btn-secondary {
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-primary);
  }
  .cookie-buttons .btn-secondary:hover {
    background: var(--bg-secondary);
  }

  .cookie-buttons .btn-primary {
    background: var(--accent);
    border: 1px solid var(--accent);
    color: white;
    box-shadow: 0 4px 10px rgba(var(--accent-rgb), 0.3);
  }
  .cookie-buttons .btn-primary:active {
    transform: scale(0.98);
  }

  @media (max-width: 640px) {
    .cookie-banner {
      bottom: 16px;
      left: 16px;
      right: 16px;
      padding: 1.25rem;
    }
    .cookie-buttons {
      flex-direction: column;
      width: 100%;
    }
    .cookie-buttons .btn {
      width: 100%;
      text-align: center;
    }
    .cookie-toggle-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 15px;
    }
  }
</style>
