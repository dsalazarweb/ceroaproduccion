---
interface Props {
  currentPhase?: number;
}
const { currentPhase = 0 } = Astro.props;

const phases = [
  { id: 0, label: "Fase 0: Linux", x: 50, y: 100 },
  { id: 1, label: "Fase 1: AWS", x: 225, y: 60 },
  { id: 2, label: "Fase 2: Docker", x: 400, y: 140 },
  { id: 3, label: "Fase 3: IaC", x: 575, y: 60 },
  { id: 4, label: "Fase 4: CI/CD", x: 750, y: 100 },
];

const paths = [
  "", 
  "C 120 100, 150 60, 225 60", 
  "C 300 60, 320 140, 400 140", 
  "C 480 140, 500 60, 575 60", 
  "C 650 60, 680 100, 750 100"  
];

const fullPath = `M ${phases[0].x} ${phases[0].y} ` + paths.slice(1).join(" ");
const activePathBlocks = paths.slice(1, currentPhase + 1);
const activePath = currentPhase > 0 ? (`M ${phases[0].x} ${phases[0].y} ` + activePathBlocks.join(" ")) : "";

const safePhase = Math.max(0, Math.min(currentPhase, phases.length - 1));
const tuxPos = phases[safePhase];
---

<div class="roadmap-graphic-container">
  <svg viewBox="0 0 800 180" xmlns="http://www.w3.org/2000/svg" class="roadmap-svg">
    <defs>
      <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="4" result="blur" />
        <feComponentTransfer in="blur" result="glow">
          <feFuncA type="linear" slope="1.5" />
        </feComponentTransfer>
        <feMerge>
          <feMergeNode in="glow" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    <!-- Background Inactive Track -->
    <path 
      d={fullPath} 
      fill="none" 
      stroke="rgba(124, 138, 255, 0.15)" 
      stroke-width="4" 
      stroke-linecap="round" 
    />

    <!-- Active Track (Only up to current phase) -->
    {currentPhase > 0 && (
      <path 
        d={activePath} 
        fill="none" 
        stroke="var(--accent)" 
        stroke-width="4" 
        stroke-linecap="round" 
        filter="url(#glow)"
      />
    )}

    {phases.map((p, i) => {
      const isActive = currentPhase >= i;
      return (
        <g class={`node ${isActive ? 'active' : ''}`} style={`transform: translate(${p.x}px, ${p.y}px)`}>
          <circle cx="0" cy="0" r="10" class="node-bg" />
          {!isActive && <circle cx="0" cy="0" r="4" class="node-core" />}
          {isActive && (
            <path d="M-3 0 L-1 2 L4 -3" fill="none" class="check-mark" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          )}
          <text x="0" y="24" class="node-label">{p.label}</text>
        </g>
      );
    })}

    <!-- Tux Rider -->
    <g class="tux-wrapper" style={`transform: translate(${tuxPos.x - 25}px, ${tuxPos.y - 42}px)`}>
      <g class="tux-animator">
        <!-- Hoverboard -->
        <rect x="5" y="38" width="40" height="4" rx="2" fill="var(--accent)" filter="url(#glow)" />
        <circle cx="12" cy="42" r="1.5" fill="#fff" opacity="0.8" />
        <circle cx="38" cy="42" r="1.5" fill="#fff" opacity="0.8" />
        
        <!-- Tux Silhouette Body -->
        <path d="M 25 2 C 15 2 12 18 12 28 C 12 36 18 40 25 40 C 32 40 38 36 38 28 C 38 18 35 2 25 2 Z" fill="#1e293b" />
        
        <!-- Tux Belly -->
        <path d="M 25 12 C 18 12 16 22 16 30 C 16 36 21 38 25 38 C 29 38 34 36 34 30 C 34 22 32 12 25 12 Z" fill="#f8fafc" />
        
        <!-- Eyes -->
        <circle cx="21" cy="18" r="1.5" fill="#1e293b" />
        <circle cx="29" cy="18" r="1.5" fill="#1e293b" />
        
        <!-- Beak -->
        <polygon points="23,21 27,21 25,24" fill="#f59e0b" />
        
        <!-- Flippers -->
        <path d="M 14 20 Q 6 25 10 32" fill="none" stroke="#1e293b" stroke-width="3.5" stroke-linecap="round" />
        <path d="M 36 20 Q 44 25 40 32" fill="none" stroke="#1e293b" stroke-width="3.5" stroke-linecap="round" />
        
        <!-- Hoverboard Plasma Thruster -->
        <path d="M 10 44 Q 25 55 40 44" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" opacity="0.4" />
      </g>
    </g>
  </svg>
</div>

<style>
  .roadmap-graphic-container {
    width: 100%;
    max-width: 800px;
    margin: 1rem auto 2rem auto;
    /* Optional visual subtle background block */
    background: radial-gradient(circle at center, rgba(var(--accent-rgb), 0.03) 0%, transparent 70%);
    border-radius: 16px;
    padding: 1rem;
  }
  
  .roadmap-svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .node-bg {
    fill: var(--bg-primary);
    stroke: var(--border-color);
    stroke-width: 2;
    transition: all 0.5s ease;
  }
  
  .node-core {
    fill: var(--text-muted);
    opacity: 0.5;
  }
  
  .node.active .node-bg {
    stroke: var(--accent);
    filter: drop-shadow(0 0 6px rgba(var(--accent-rgb), 0.6));
    fill: var(--bg-secondary);
  }
  
  .check-mark {
    color: var(--accent);
  }
  
  .node-label {
    fill: var(--text-secondary);
    font-size: 12px;
    font-weight: 600;
    text-anchor: middle;
    font-family: inherit;
    transition: fill 0.3s;
  }
  
  .node.active .node-label {
    fill: var(--accent);
    filter: drop-shadow(0 0 2px rgba(var(--accent-rgb), 0.2));
  }

  /* Transition for Tux Wrapper mapping exactly to points horizontally/vertically */
  .tux-wrapper {
    transition: transform 1s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Levitating engine float */
  .tux-animator {
    animation: floatTux 3s ease-in-out infinite;
    transform-origin: center bottom;
  }
  
  @keyframes floatTux {
    0%, 100% { transform: translateY(0px) scale(1); }
    50% { transform: translateY(-3px) scale(1.02); }
  }
</style>
