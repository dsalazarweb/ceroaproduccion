---
import { AUTHOR, AUTHOR_GITHUB, AUTHOR_LINKEDIN } from '../consts';
const today = new Date();
---

<footer>
  <div class="footer-inner">

    <div class="footer-top">
      <div class="footer-col">
        <h3>Sitio</h3>
        <ul>
          <li><a href="/about">Sobre mí</a></li>
          <li><a href="/roadmap">Roadmap</a></li>
          <li><a href="/contacto">Contacto</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3>Conectar</h3>
        <ul>
          <li>
            <a href={AUTHOR_GITHUB} target="_blank" rel="noopener noreferrer">GitHub</a>
          </li>
          <li>
            <a href={AUTHOR_LINKEDIN} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          </li>
          <li>
            <a href="/rss.xml" target="_blank">RSS Feed</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="copyright">
        &copy; {today.getFullYear()} {AUTHOR} / Gravelca &middot; ceroaproduccion.dev
      </p>
      <nav class="legal-links">
        <a href="/privacidad">Privacidad</a>
        <a href="/terminos">Términos</a>
        <a href="/cookies">Cookies</a>
      </nav>
    </div>

  </div>
</footer>

<style>
  footer {
    background-color: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    margin-top: 4em;
    padding: 3em 1.5em 2em;
    transition: background-color 0.2s ease;
  }
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .footer-top {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2em;
    margin-bottom: 3em;
    max-width: 400px;
  }
  .footer-col h3 {
    font-size: 0.75em;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin: 0 0 1em 0;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6em;
  }
  .footer-col ul li a {
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 0.95em;
    transition: color 0.2s;
  }
  .footer-col ul li a:hover {
    color: var(--text-primary);
  }
  .footer-bottom {
    border-top: 1px solid var(--border-color);
    padding-top: 1.5em;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1em;
  }
  .copyright {
    font-size: 0.85em;
    color: var(--text-muted);
    margin: 0;
  }
  .legal-links {
    display: flex;
    gap: 1.5em;
  }
  .legal-links a {
    font-size: 0.85em;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .legal-links a:hover {
    color: var(--text-secondary);
  }
  @media (max-width: 480px) {
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
