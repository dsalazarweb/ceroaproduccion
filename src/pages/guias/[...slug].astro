---
export const prerender = true;
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guias = (await getCollection('guias'))
    .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());
  
  return guias.map((guia, index) => ({
    params: { slug: guia.id },
    props: {
      guia,
      prev: index < guias.length - 1 ? guias[index + 1] : null,
      next: index > 0 ? guias[index - 1] : null,
    },
  }));
}

const { guia, prev, next } = Astro.props;
const { Content } = await render(guia);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={`${guia.data.titulo} — ${SITE_TITLE}`} description={guia.data.descripcion} />
    <style>
      .guia-header {
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border-color);
      }
      .difficulty {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        background: #10b981;
        color: white;
        margin-bottom: 1rem;
        display: inline-block;
      }
      .guia-title {
        font-size: 3rem;
        margin: 0 0 1rem 0;
        line-height: 1.1;
      }
      .guia-meta {
        display: flex;
        justify-content: space-between;
        color: var(--text-secondary);
        font-size: 0.95rem;
      }
      .tags {
        display: flex;
        gap: 0.5rem;
      }
      .tag {
        background: var(--bg-secondary);
        padding: 0.1rem 0.5rem;
        border-radius: 4px;
        font-size: 0.8rem;
        color: var(--text-muted);
      }
      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.9rem;
        margin-bottom: 2rem;
        transition: color 0.2s;
      }
      .back-link:hover {
        color: var(--accent);
      }
      .prose {
        max-width: 100%;
        margin-bottom: 4rem;
      }
      .guia-nav {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border-color);
      }
      .nav-card {
        display: flex;
        flex-direction: column;
        padding: 1rem;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        text-decoration: none;
        transition: border-color 0.2s;
      }
      .nav-card:hover {
        border-color: #10b981;
      }
      .nav-label {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 0.25rem;
      }
      .nav-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
      }
      .next { text-align: right; grid-column: 2; }
      .prev { text-align: left; grid-column: 1; }

      @media (max-width: 720px) {
        .guia-title { font-size: 2.2rem; }
        .guia-nav { grid-template-columns: 1fr; }
        .next { grid-column: 1; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <a href="/guias" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Volver a Guías
      </a>
      <article class="prose">
        <header class="guia-header">
          <span class="difficulty">{guia.data.dificultad}</span>
          <h1 class="guia-title">{guia.data.titulo}</h1>
          <div class="guia-meta">
            <FormattedDate date={guia.data.fecha} />
            <div class="tags">
              {guia.data.tags.map(tag => <span class="tag">#{tag}</span>)}
            </div>
          </div>
        </header>
        <Content />
        
        <nav class="guia-nav">
          {prev && (
            <a href={`/guias/${prev.id}`} class="nav-card prev">
              <span class="nav-label">Anterior</span>
              <span class="nav-title">{prev.data.titulo}</span>
            </a>
          )}
          {next && (
            <a href={`/guias/${next.id}`} class="nav-card next">
              <span class="nav-label">Siguiente</span>
              <span class="nav-title">{next.data.titulo}</span>
            </a>
          )}
        </nav>
      </article>
    </main>
    <Footer />
  </body>
</html>
