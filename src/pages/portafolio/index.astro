---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={`Portafolio — ${SITE_TITLE}`} description="Proyectos y despliegues reales. Desde infraestructura como código hasta aplicaciones contenerizadas." />
    <style>
      .portfolio-header {
        margin-bottom: 4rem;
        text-align: center;
      }
      .portfolio-header h1 {
        font-size: 3.5rem;
        margin-bottom: 1rem;
      }
      .portfolio-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2rem;
      }
      .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 4rem 2rem;
        background: var(--bg-secondary);
        border: 2px dashed var(--border-color);
        border-radius: 16px;
      }
      .empty-state h2 {
        color: var(--text-secondary);
        margin-bottom: 1rem;
      }
      .empty-state p {
        color: var(--text-muted);
        max-width: 400px;
        margin: 0 auto;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <header class="portfolio-header">
        <h1>Portafolio</h1>
        <p>Proyectos terminados y arquitecturas reales en producción.</p>
      </header>

      <div class="portfolio-grid">
        <div class="empty-state">
          <h2>Proyectos en Construcción</h2>
          <p>Actualmente estoy documentando mis primeros despliegues en los Labs. Muy pronto verás aquí los proyectos consolidados.</p>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
