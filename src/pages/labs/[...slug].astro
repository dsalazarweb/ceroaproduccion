---
export const prerender = true;
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const labs = (await getCollection('labs'))
    .sort((a, b) => a.data.dia - b.data.dia);
  
  return labs.map((lab, index) => ({
    params: { slug: lab.id },
    props: {
      lab,
      prev: index > 0 ? labs[index - 1] : null,
      next: index < labs.length - 1 ? labs[index + 1] : null,
    },
  }));
}

const { lab, prev, next } = Astro.props;
const { Content } = await render(lab);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={`${lab.data.titulo} — ${SITE_TITLE}`} description={lab.data.descripcion} />
    <style>
      .lab-header {
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border-color);
      }
      .lab-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
      }
      .badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .badge-fase {
        background-color: var(--accent);
        color: white;
      }
      .badge-dia {
        background-color: var(--bg-secondary);
        color: var(--text-primary);
        border: 1px solid var(--border-color);
      }
      .lab-title {
        font-size: 3rem;
        margin: 0 0 1rem 0;
        line-height: 1.1;
      }
      .lab-date-tags {
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: var(--text-secondary);
        font-size: 0.95rem;
        flex-wrap: wrap;
        gap: 1rem;
      }
      .tags {
        display: flex;
        gap: 0.5rem;
      }
      .tag {
        background: var(--bg-secondary);
        padding: 0.1rem 0.5rem;
        border-radius: 4px;
        font-size: 0.8rem;
        color: var(--text-muted);
      }
      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.9rem;
        margin-bottom: 2rem;
        transition: color 0.2s;
      }
      .back-link:hover {
        color: var(--accent);
      }
      .prose {
        max-width: 100%;
        margin-bottom: 4rem;
      }
      /* Navegación entre labs */
      .lab-nav {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border-color);
      }
      .nav-card {
        display: flex;
        flex-direction: column;
        padding: 1rem;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        text-decoration: none;
        transition: border-color 0.2s;
      }
      .nav-card:hover {
        border-color: var(--accent);
      }
      .nav-label {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 0.25rem;
      }
      .nav-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
      }
      .next { text-align: right; grid-column: 2; }
      .prev { text-align: left; grid-column: 1; }

      /* Estilos para tablas dentro del Markdown */
      :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 2rem 0;
        font-size: 0.95rem;
      }
      :global(th), :global(td) {
        padding: 0.75rem;
        border: 1px solid var(--border-color);
        text-align: left;
      }
      :global(th) {
        background-color: var(--bg-secondary);
        font-weight: 700;
      }
      /* Estilos para blockquotes */
      :global(blockquote) {
        background: var(--bg-secondary);
        border-radius: 0 8px 8px 0;
        margin: 2rem 0;
      }
      .share-container {
        margin: 4rem 0 2rem;
        padding-top: 2rem;
        border-top: 1px dashed var(--border-color);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }
      .share-container p {
        margin: 0;
        font-weight: 600;
        color: var(--text-secondary);
        font-size: 1.1rem;
      }
      .share-buttons {
        display: flex;
        gap: 1rem;
      }
      .share-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--bg-secondary);
        color: var(--text-secondary);
        border: 1px solid var(--border-color);
        transition: all 0.2s;
        text-decoration: none;
      }
      .share-btn:hover {
        background: var(--accent);
        color: white;
        border-color: var(--accent);
        transform: translateY(-2px);
      }
      @media (max-width: 720px) {
        .lab-title { font-size: 2.2rem; }
        .lab-nav { grid-template-columns: 1fr; }
        .next { grid-column: 1; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <a href="/labs" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Volver a Labs
      </a>
      <article class="prose">
        <header class="lab-header">
          <div class="lab-meta">
            <span class="badge badge-fase">Fase {lab.data.fase}</span>
            <span class="badge badge-dia">Día {lab.data.dia}</span>
          </div>
          <h1 class="lab-title">{lab.data.titulo}</h1>
          <div class="lab-date-tags">
            <FormattedDate date={lab.data.fecha} />
            <div class="tags">
              {lab.data.tags.map(tag => <span class="tag">#{tag}</span>)}
            </div>
          </div>
        </header>
        <Content />
        
        <div class="share-container">
          <p>¿Te resultó útil? ¡Compártelo!</p>
          <div class="share-buttons">
            <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(lab.data.titulo)}&url=${encodeURIComponent(Astro.url)}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Compartir en Twitter">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
            </a>
            <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url)}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Compartir en LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
          </div>
        </div>

        <nav class="lab-nav">
          {prev && (
            <a href={`/labs/${prev.id}`} class="nav-card prev">
              <span class="nav-label">Anterior</span>
              <span class="nav-title">Día {prev.data.dia}: {prev.data.titulo}</span>
            </a>
          )}
          {next && (
            <a href={`/labs/${next.id}`} class="nav-card next">
              <span class="nav-label">Siguiente</span>
              <span class="nav-title">Día {next.data.dia}: {next.data.titulo}</span>
            </a>
          )}
        </nav>
      </article>
    </main>
    <Footer />
  </body>
</html>
