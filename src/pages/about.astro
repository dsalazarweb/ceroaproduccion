---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={`About — ${SITE_TITLE}`} description="Venezuelan professional based in Colombia, transitioning from Customer Operations to DevOps & Cloud Administration." />
  </head>
  <body>
    <Header />
    <main>
      <h1>About</h1>
      <p>Venezuelan professional based in Colombia, transitioning from 6+ years in technical operations to DevOps & Cloud Administration.</p>
      <p>Building real skills through hands-on practice, documented publicly from day one.</p>
      <h2>Current Focus</h2>
      <p>Linux · Bash · Python · Docker · AWS · Terraform · Kubernetes</p>
      <h2>Background</h2>
      <p>My operations background gives me a unique perspective — I've seen production systems from the customer impact side. Now I'm learning to build the infrastructure that prevents those incidents.</p>
    </main>
    <Footer />
  </body>
</html>
