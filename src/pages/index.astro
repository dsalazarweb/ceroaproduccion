---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

import RoadmapGraphic from '../components/RoadmapGraphic.astro';

const allLabs = await getCollection('labs', ({ data }) => !data.draft);
const latestLabs = allLabs
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 3);

const allGuias = await getCollection('guias', ({ data }) => !data.draft);
const latestGuias = allGuias
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 3);

const maxPhase = allLabs.length > 0 ? Math.max(...allLabs.map((lab) => lab.data.fase || 0)) : 0;
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={`${SITE_TITLE} | DevOps y Cloud`} description={SITE_DESCRIPTION} />
    <style>
      body::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        z-index: -1;
        pointer-events: none;
      }
      :global(html[data-theme='dark']) body::before {
        background-image: radial-gradient(rgba(255,255,255, 0.05) 1px, transparent 1px);
        background-size: 24px 24px;
      }
      :global(html[data-theme='light']) body::before {
        background-image: radial-gradient(rgba(0,0,0, 0.05) 1px, transparent 1px);
        background-size: 24px 24px;
      }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-up {
        animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
      }
      .delay-1 { animation-delay: 0.1s; }
      .delay-2 { animation-delay: 0.2s; }
      .delay-3 { animation-delay: 0.3s; }
      .delay-4 { animation-delay: 0.4s; }

      .hero-graphic {
        margin-top: 1rem;
        position: relative;
        max-width: 1000px;
        margin-left: auto;
        margin-right: auto;
        pointer-events: none;
      }
      .hero-graphic img {
        display: block;
        width: 100%;
        height: auto;
        opacity: 0.65;
        /* El fade edge infinito - lo diluye en el fondo */
        -webkit-mask-image: radial-gradient(ellipse at center, rgba(0,0,0,1) 10%, rgba(0,0,0,0) 70%);
        mask-image: radial-gradient(ellipse at center, rgba(0,0,0,1) 10%, rgba(0,0,0,0) 70%);
        mix-blend-mode: screen; 
      }

      .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 1.2rem;
        background: rgba(245, 158, 11, 0.1); /* Amber/Beta color */
        border: 1px solid rgba(245, 158, 11, 0.2);
        color: #f59e0b;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 2.5rem;
        box-shadow: 0 4px 15px rgba(245, 158, 11, 0.1);
      }
      .status-pulse {
        width: 8px;
        height: 8px;
        background: #f59e0b;
        border-radius: 50%;
        box-shadow: 0 0 10px #f59e0b;
        animation: ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
      }
      @keyframes ping {
        0% { transform: scale(1); opacity: 1; }
        75%, 100% { transform: scale(2.5); opacity: 0; }
      }

      .hero {
        padding: 3rem 0 3rem 0;
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
      }
      .hero h1 {
        font-size: 4rem;
        line-height: 1.1;
        margin-bottom: 1.25rem;
        background: linear-gradient(to bottom right, var(--text-primary), var(--accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .hero p {
        font-size: 1.25rem;
        color: var(--text-secondary);
        margin-bottom: 2rem;
        line-height: 1.6;
      }
      .cta-group {
        display: flex;
        gap: 1rem;
        justify-content: center;
      }
      .btn {
        display: inline-block;
        padding: 0.8rem 2rem;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        transition: transform 0.2s, opacity 0.2s;
      }
      .btn-primary {
        background: var(--accent);
        color: white;
        box-shadow: 0 4px 15px -3px rgba(var(--accent-rgb), 0.4);
      }
      .btn-secondary {
        background: var(--bg-secondary);
        color: var(--text-primary);
        border: 1px solid var(--border-color);
      }
      .btn:hover {
        transform: translateY(-2px);
      }
      .btn-primary:hover {
        box-shadow: 0 8px 25px -5px rgba(var(--accent-rgb), 0.6);
        opacity: 0.95;
      }

      .section-title {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 2rem;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 1rem;
      }
      .section-title h2 {
        margin: 0;
        font-size: 1.8rem;
      }
      .section-title a {
        font-size: 0.9rem;
        text-decoration: none;
        font-weight: 600;
      }

      .labs-preview {
        display: grid;
        gap: 1.5rem;
      }
      .lab-mini-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem;
        background: rgba(var(--bg-secondary-rgb), 0.6);
        backdrop-filter: blur(10px);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
      }
      .lab-mini-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 4px; height: 100%;
        background: var(--accent);
        transform: scaleY(0);
        transform-origin: bottom;
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .lab-mini-card:hover {
        border-color: rgba(var(--accent-rgb), 0.4);
        transform: translateY(-3px);
        box-shadow: 0 15px 30px -10px rgba(0,0,0,0.15);
      }
      .lab-mini-card:hover::before {
        transform: scaleY(1);
      }
      .lab-mini-card svg {
        opacity: 0.5;
        transition: all 0.3s;
      }
      .lab-mini-card:hover svg {
        opacity: 1;
        color: var(--accent);
        transform: translateX(4px);
      }
      .lab-info {
        flex-grow: 1;
        padding-right: 1.5rem;
      }
      .lab-tags {
        display: flex;
        gap: 0.5rem;
        margin-top: 0.8rem;
        flex-wrap: wrap;
      }
      .lab-tag {
        font-size: 0.7rem;
        padding: 0.2rem 0.6rem;
        background: var(--bg-primary);
        border: 1px solid var(--border-color);
        border-radius: 4px;
        color: var(--text-secondary);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .lab-info h3 {
        margin: 0 0 0.25rem 0;
        font-size: 1.2rem;
      }
      .lab-meta {
        font-size: 0.85rem;
        color: var(--text-muted);
      }
      .lab-day {
        font-weight: 700;
        color: var(--accent);
        margin-right: 0.5rem;
      }

      .tech-strip-wrapper {
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        background: var(--bg-secondary);
        border-top: 1px solid var(--border-color);
        border-bottom: 1px solid var(--border-color);
        padding: 2rem 1.5rem;
        margin-top: 1rem;
        margin-bottom: 3.5rem;
      }
      .tech-strip-label {
        text-align: center;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 3px;
        font-weight: 700;
        color: var(--text-muted);
        margin-bottom: 1rem;
      }
      .tech-strip-items {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        max-width: 900px;
        margin: 0 auto;
      }
      .tech-strip-items .separator {
        width: 1px;
        height: 18px;
        background: var(--border-color);
      }
      .tech-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.4rem 0.75rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-secondary);
        transition: color 0.3s, background 0.3s, box-shadow 0.3s;
        cursor: default;
      }
      .tech-item:hover {
        color: var(--accent);
        background: rgba(var(--accent-rgb), 0.08);
        box-shadow: 0 0 15px rgba(var(--accent-rgb), 0.05);
      }
      .tech-item svg {
        opacity: 0.6;
        transition: opacity 0.3s;
        flex-shrink: 0;
      }
      .tech-item:hover svg {
        opacity: 1;
      }

      @media (max-width: 850px) {
        .tech-strip-items { gap: 0.5rem; }
        .tech-strip-items .separator { display: none; }
      }

      @media (max-width: 720px) {
        .hero h1 { font-size: 2.8rem; }
        .hero { padding: 2rem 0 2rem 0; }
        .cta-group { flex-direction: column; }
        .tech-strip-wrapper { padding: 2rem 1rem; }
        .tech-strip-items { gap: 0.5rem; }
        .tech-strip-items .separator { display: none; }
        .tech-item { padding: 0.4rem 0.75rem; font-size: 0.85rem; }
      }

      /* ===== Sección dual: Labs + Guías ===== */
      .content-preview {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 3rem;
        margin-bottom: 1rem;
      }
      .preview-column h2 {
        font-size: 1.8rem;
        margin: 0;
      }

      /* Cards de guía compactas */
      .guia-mini-card {
        display: flex;
        flex-direction: column;
        padding: 1.25rem;
        background: rgba(var(--bg-secondary-rgb), 0.6);
        backdrop-filter: blur(10px);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
      }
      .guia-mini-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 4px; height: 100%;
        background: #10b981;
        transform: scaleY(0);
        transform-origin: bottom;
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .guia-mini-card:hover {
        border-color: rgba(16, 185, 129, 0.4);
        transform: translateY(-3px);
        box-shadow: 0 15px 30px -10px rgba(0,0,0,0.15);
      }
      .guia-mini-card:hover::before {
        transform: scaleY(1);
      }
      .guia-mini-card h3 {
        margin: 0 0 0.5rem 0;
        font-size: 1.05rem;
        line-height: 1.3;
      }
      .guia-mini-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: auto;
        padding-top: 0.5rem;
      }
      .guia-difficulty {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        padding: 0.15rem 0.5rem;
        border-radius: 4px;
        background: var(--bg-primary);
        border: 1px solid var(--border-color);
      }
      .diff-principiante { color: #10b981; }
      .diff-intermedio { color: #f59e0b; }
      .diff-avanzado { color: #ef4444; }

      .guias-preview {
        display: grid;
        gap: 1rem;
      }

      @media (max-width: 720px) {
        .content-preview {
          grid-template-columns: 1fr;
          gap: 2.5rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <div class="status-badge animate-fade-up">
          <span class="status-pulse"></span>
          Estado: En Fase de Desarrollo
        </div>
        <h1 class="animate-fade-up delay-1">{SITE_TITLE}</h1>
        <p class="animate-fade-up delay-2">DevOps y Cloud en español — del origen hasta una arquitectura sólida y escalable. Guías, errores reales y progreso continuo.</p>
        <div class="cta-group animate-fade-up delay-3">
          <a href="/labs" class="btn btn-primary">Empezar el viaje</a>
          <a href="/about" class="btn btn-secondary">Sobre mí</a>
        </div>
        
        <div class="hero-graphic animate-fade-up delay-4">
          <RoadmapGraphic currentPhase={maxPhase} />
        </div>
      </section>

      <!-- Tech Strip -->
      <div class="tech-strip-wrapper">
        <p class="tech-strip-label">Stack Base & Roadmap</p>
        <div class="tech-strip-items">
          <div class="tech-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
            Astro
          </div>
          <div class="separator"></div>
          <div class="tech-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>
            Tailwind
          </div>
          <div class="separator"></div>
          <div class="tech-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
            Bash
          </div>
          <div class="separator"></div>
          <div class="tech-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            Linux
          </div>
          <div class="separator"></div>
          <div class="tech-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12H2"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/><line x1="6" y1="16" x2="6.01" y2="16"/><line x1="10" y1="16" x2="10.01" y2="16"/></svg>
            Docker
          </div>
          <div class="separator"></div>
          <div class="tech-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
            AWS
          </div>
          <div class="separator"></div>
          <div class="tech-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
            Terraform
          </div>
          <div class="separator"></div>
          <div class="tech-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            Kubernetes
          </div>
        </div>
      </div>

      <div class="content-preview">
        <!-- Columna Labs -->
        <div class="preview-column">
          <div class="section-title">
            <h2>Últimos Labs</h2>
            <a href="/labs">Ver todos →</a>
          </div>
          <div class="labs-preview">
            {latestLabs.map((lab) => (
              <a href={`/labs/${lab.id}`} class="lab-mini-card">
                <div class="lab-info">
                  <span class="lab-meta">
                    <span class="lab-day">Día {lab.data.dia}</span>
                    <FormattedDate date={lab.data.fecha} />
                  </span>
                  <h3>{lab.data.titulo}</h3>
                  <div class="lab-tags">
                    {lab.data.tags.slice(0, 3).map(tag => (
                      <span class="lab-tag">{tag}</span>
                    ))}
                  </div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </a>
            ))}
          </div>
        </div>

        <!-- Columna Guías -->
        <div class="preview-column">
          <div class="section-title">
            <h2>Últimas Guías</h2>
            <a href="/guias">Ver todas →</a>
          </div>
          <div class="guias-preview">
            {latestGuias.map((guia) => (
              <a href={`/guias/${guia.id}`} class="guia-mini-card">
                <span class={`guia-difficulty diff-${guia.data.dificultad}`}>
                  {guia.data.dificultad}
                </span>
                <h3>{guia.data.titulo}</h3>
                <div class="guia-mini-meta">
                  <FormattedDate date={guia.data.fecha} />
                  {guia.data.tiempo_lectura && <span>{guia.data.tiempo_lectura} min</span>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
