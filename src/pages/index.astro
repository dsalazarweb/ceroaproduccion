---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const latestLabs = (await getCollection('labs', ({ data }) => !data.draft))
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={`${SITE_TITLE} | DevOps y Cloud`} description={SITE_DESCRIPTION} />
    <style>
      .hero {
        padding: 3rem 0 3rem 0;
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
      }
      .hero h1 {
        font-size: 4rem;
        line-height: 1.1;
        margin-bottom: 1.25rem;
        background: linear-gradient(to bottom right, var(--text-primary), var(--accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .hero p {
        font-size: 1.25rem;
        color: var(--text-secondary);
        margin-bottom: 2rem;
        line-height: 1.6;
      }
      .cta-group {
        display: flex;
        gap: 1rem;
        justify-content: center;
      }
      .btn {
        display: inline-block;
        padding: 0.8rem 2rem;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        transition: transform 0.2s, opacity 0.2s;
      }
      .btn-primary {
        background: var(--accent);
        color: white;
      }
      .btn-secondary {
        background: var(--bg-secondary);
        color: var(--text-primary);
        border: 1px solid var(--border-color);
      }
      .btn:hover {
        transform: translateY(-2px);
        opacity: 0.9;
      }

      .section-title {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 2rem;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 1rem;
      }
      .section-title h2 {
        margin: 0;
        font-size: 1.8rem;
      }
      .section-title a {
        font-size: 0.9rem;
        text-decoration: none;
        font-weight: 600;
      }

      .labs-preview {
        display: grid;
        gap: 1.5rem;
      }
      .lab-mini-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        text-decoration: none;
        color: inherit;
        transition: border-color 0.2s, transform 0.2s;
      }
      .lab-mini-card:hover {
        border-color: var(--accent);
        transform: translateX(4px);
      }
      .lab-info h3 {
        margin: 0 0 0.25rem 0;
        font-size: 1.2rem;
      }
      .lab-meta {
        font-size: 0.85rem;
        color: var(--text-muted);
      }
      .lab-day {
        font-weight: 700;
        color: var(--accent);
        margin-right: 0.5rem;
      }

      .tech-strip-wrapper {
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        background: var(--bg-secondary);
        border-top: 1px solid var(--border-color);
        border-bottom: 1px solid var(--border-color);
        padding: 2rem 1.5rem;
        margin-top: 1rem;
        margin-bottom: 3.5rem;
      }
      .tech-strip-label {
        text-align: center;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 3px;
        font-weight: 700;
        color: var(--text-muted);
        margin-bottom: 1rem;
      }
      .tech-strip-items {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        max-width: 900px;
        margin: 0 auto;
      }
      .tech-strip-items .separator {
        width: 1px;
        height: 18px;
        background: var(--border-color);
      }
      .tech-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.4rem 0.75rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-secondary);
        transition: color 0.3s, background 0.3s, box-shadow 0.3s;
        cursor: default;
      }
      .tech-item:hover {
        color: var(--accent);
        background: rgba(var(--accent-rgb), 0.08);
        box-shadow: 0 0 15px rgba(var(--accent-rgb), 0.05);
      }
      .tech-item svg {
        opacity: 0.6;
        transition: opacity 0.3s;
        flex-shrink: 0;
      }
      .tech-item:hover svg {
        opacity: 1;
      }

      @media (max-width: 850px) {
        .tech-strip-items { gap: 0.5rem; }
        .tech-strip-items .separator { display: none; }
      }

      @media (max-width: 720px) {
        .hero h1 { font-size: 2.8rem; }
        .hero { padding: 2rem 0 2rem 0; }
        .cta-group { flex-direction: column; }
        .tech-strip-wrapper { padding: 2rem 1rem; }
        .tech-strip-items { gap: 0.5rem; }
        .tech-strip-items .separator { display: none; }
        .tech-item { padding: 0.4rem 0.75rem; font-size: 0.85rem; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <h1>{SITE_TITLE}</h1>
        <p>{SITE_DESCRIPTION}</p>
        <div class="cta-group">
          <a href="/labs" class="btn btn-primary">Explorar Labs</a>
          <a href="/about" class="btn btn-secondary">Mi Historia</a>
        </div>
      </section>

      <!-- Tech Strip -->
      <div class="tech-strip-wrapper">
        <p class="tech-strip-label">Tecnologías del roadmap</p>
        <div class="tech-strip-items">
          <div class="tech-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
            Bash
          </div>
          <div class="separator"></div>
          <div class="tech-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            Linux
          </div>
          <div class="separator"></div>
          <div class="tech-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12H2"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/><line x1="6" y1="16" x2="6.01" y2="16"/><line x1="10" y1="16" x2="10.01" y2="16"/></svg>
            Docker
          </div>
          <div class="separator"></div>
          <div class="tech-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
            AWS
          </div>
          <div class="separator"></div>
          <div class="tech-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
            Terraform
          </div>
          <div class="separator"></div>
          <div class="tech-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            Kubernetes
          </div>
        </div>
      </div>

      <section>
        <div class="section-title">
          <h2>Últimos Labs</h2>
          <a href="/labs">Ver todos →</a>
        </div>
        <div class="labs-preview">
          {latestLabs.map((lab) => (
            <a href={`/labs/${lab.id}`} class="lab-mini-card">
              <div class="lab-info">
                <span class="lab-meta">
                  <span class="lab-day">Día {lab.data.dia}</span>
                  <FormattedDate date={lab.data.fecha} />
                </span>
                <h3>{lab.data.titulo}</h3>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          ))}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
