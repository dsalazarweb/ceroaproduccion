# Normaliza saltos de línea — el repo siempre guarda LF.
# Evita que archivos aparezcan como "modificados" al alternar Windows/WSL.
* text=auto eol=lf

# Binarios — nunca aplicar conversión de línea.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  text eol=lf
*.woff binary
*.woff2 binary
*.pdf  binary
